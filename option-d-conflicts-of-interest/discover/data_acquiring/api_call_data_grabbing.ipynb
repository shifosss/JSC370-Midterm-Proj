    "df_eda = df_master.copy()\n",
    "\n",
    "# --- Plot 3: Results-posting and publication rate by sponsor class ---\n",
    "sponsor_outcomes = (\n",
    "    df_eda.groupby(\"lead_sponsor_class\", as_index=False)\n",
    "    .agg(\n",
